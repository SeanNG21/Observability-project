{{ define "telegram.critical.message" }}
{{- if eq .Status "firing" -}}
🔴 <b>ALERT FIRING</b>
{{- else -}}
✅ <b>ALERT RESOLVED</b>
{{- end }}

<b>Alert:</b> {{ .CommonAnnotations.summary }}
<b>Severity:</b> {{ .CommonLabels.severity | toUpper }}
<b>Env:</b> {{ .CommonLabels.env }}
<b>Time:</b> {{ .CommonAnnotations.startsAt | default "now" }}

{{ range .Alerts }}
<b>Instance:</b> {{ .Labels.instance | default "N/A" }}
<b>Hostname:</b> {{ .Labels.hostname | default "N/A" }}
<b>Service:</b> {{ .Labels.service | default "N/A" }}
<b>Detail:</b> {{ .Annotations.description | default "No description" }}

{{ if .Annotations.runbook }}
<b>📋 Runbook:</b>
<pre>{{ .Annotations.runbook }}</pre>
{{ end }}

<b>🔗 Grafana:</b> <a href="http://grafana.yourdomain.com/explore">Explore</a>
<b>🔗 Alertmanager:</b> <a href="http://alertmanager.yourdomain.com/#/alerts">Alerts</a>
{{ end }}
{{ end }}

{{ define "email.critical.html" }}
<!DOCTYPE html>
<html>
<head>
<style>
  body { font-family: Arial, sans-serif; background: #f5f5f5; }
  .container { max-width: 800px; margin: 20px auto; background: white; border-radius: 8px; overflow: hidden; }
  .header { background: {{ if eq .Status "firing" }}#dc3545{{ else }}#28a745{{ end }}; color: white; padding: 20px; }
  .header h1 { margin: 0; font-size: 24px; }
  .body { padding: 20px; }
  .alert-box { border-left: 4px solid {{ if eq .Status "firing" }}#dc3545{{ else }}#28a745{{ end }}; padding: 15px; margin: 10px 0; background: #f8f9fa; }
  .label { font-weight: bold; color: #333; }
  .value { color: #666; }
  .runbook { background: #272822; color: #f8f8f2; padding: 15px; border-radius: 4px; font-family: monospace; font-size: 13px; white-space: pre-wrap; }
  .footer { padding: 15px; background: #f5f5f5; font-size: 12px; color: #888; }
  .btn { display: inline-block; padding: 8px 16px; background: #007bff; color: white; text-decoration: none; border-radius: 4px; margin: 5px; }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>{{ if eq .Status "firing" }}🔴 ALERT FIRING{{ else }}✅ ALERT RESOLVED{{ end }}</h1>
    <p>{{ .CommonAnnotations.summary }}</p>
  </div>
  <div class="body">
    <p>
      <span class="label">Severity:</span> <span class="value">{{ .CommonLabels.severity | toUpper }}</span><br>
      <span class="label">Environment:</span> <span class="value">{{ .CommonLabels.env }}</span><br>
      <span class="label">Cluster:</span> <span class="value">{{ .CommonLabels.cluster }}</span><br>
      <span class="label">Alert Count:</span> <span class="value">{{ len .Alerts }}</span>
    </p>

    {{ range .Alerts }}
    <div class="alert-box">
      <p>
        <span class="label">Alert:</span> <span class="value">{{ .Labels.alertname }}</span><br>
        <span class="label">Instance:</span> <span class="value">{{ .Labels.instance | default "N/A" }}</span><br>
        <span class="label">Hostname:</span> <span class="value">{{ .Labels.hostname | default "N/A" }}</span><br>
        <span class="label">Service:</span> <span class="value">{{ .Labels.service | default "N/A" }}</span><br>
        <span class="label">Started:</span> <span class="value">{{ .StartsAt.Format "2006-01-02 15:04:05 MST" }}</span>
      </p>
      <p><span class="label">Description:</span><br>{{ .Annotations.description | default "No description" }}</p>
      {{ if .Annotations.runbook }}
      <p><span class="label">📋 Runbook:</span></p>
      <div class="runbook">{{ .Annotations.runbook }}</div>
      {{ end }}
    </div>
    {{ end }}

    <p>
      <a href="http://grafana.yourdomain.com" class="btn">📊 Grafana</a>
      <a href="http://alertmanager.yourdomain.com/#/alerts" class="btn">🔔 Alertmanager</a>
      <a href="http://kibana.yourdomain.com" class="btn">📋 Kibana Logs</a>
    </p>
  </div>
  <div class="footer">
    Generated by Alertmanager | {{ .CommonLabels.cluster }} | {{ now.Format "2006-01-02 15:04:05" }}
  </div>
</div>
</body>
</html>
{{ end }}

{{ define "email.default.html" }}
<!DOCTYPE html>
<html>
<body style="font-family: Arial, sans-serif;">
<div style="max-width: 700px; margin: 0 auto; padding: 20px;">
  <h2 style="color: {{ if eq .Status "firing" }}#dc3545{{ else }}#28a745{{ end }};">
    {{ if eq .Status "firing" }}⚠️ Alert Firing{{ else }}✅ Alert Resolved{{ end }}
  </h2>
  <p><strong>{{ .CommonAnnotations.summary }}</strong></p>
  <p>Severity: {{ .CommonLabels.severity }} | Env: {{ .CommonLabels.env }}</p>
  {{ range .Alerts }}
  <div style="border-left: 3px solid #ffc107; padding-left: 10px; margin: 10px 0;">
    <p>{{ .Annotations.description }}</p>
    <small>Instance: {{ .Labels.instance }} | Started: {{ .StartsAt.Format "15:04:05" }}</small>
  </div>
  {{ end }}
  <p><a href="http://grafana.yourdomain.com">View in Grafana</a></p>
</div>
</body>
</html>
{{ end }}
